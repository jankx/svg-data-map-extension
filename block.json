{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "jankx/svg-data-map",
    "version": "1.0.0",
    "title": "Jankx SVG Data Map",
    "category": "jankx",
    "description": "Interactive SVG map with dynamic WordPress data binding.",
    "attributes": {
        "config": {
            "type": "object",
            "default": {}
        }
    },
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "editorScript": "file:./dist/assets/index.js",
    "editorStyle": "file:./dist/assets/index.css",
    "script": "file:./dist/assets/frontend.js",
    "style": "file:./dist/assets/index.css"
}