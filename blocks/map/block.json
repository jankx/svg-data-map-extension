{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "jankx/svg-data-map",
    "version": "1.0.0",
    "title": "Jankx SVG Data Map",
    "category": "jankx",
    "description": "Interactive SVG map with dynamic WordPress data binding.",
    "attributes": {
        "mapId": {
            "type": "string",
            "default": "default-map"
        },
        "config": {
            "type": "object",
            "default": {}
        },
        "zoomScale": {
            "type": "number",
            "default": 1
        },
        "zoomPositionX": {
            "type": "number",
            "default": 0
        },
        "zoomPositionY": {
            "type": "number",
            "default": 0
        }
    },
    "supports": {
        "html": false,
        "align": [
            "wide",
            "full"
        ]
    },
    "editorScript": "file:../../dist/assets/index.js",
    "editorStyle": "file:../../dist/assets/index.css",
    "style": "file:../../dist/assets/index.css",
    "renderCallback": "SvgDataMapBlock::render"
}